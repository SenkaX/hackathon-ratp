{% extends 'base.html.twig' %}

{% block title %}Moderation des tickets - Dashboard Kanban{% endblock %}

{% block body %}
    <style>

        :root {
            --jade: #00c4b3;
            --jade-dim: #00a396;
            --azur: #5b8def;
            --azur-dim: #3272d9;
            --coq: #e2231a;
            --yellow: #f0b429;
            --green: #2ea043;
            --bg: #ffffff;
            --surface: #f8fbff;
            --surface-alt: #eef5fb;
            --border: #d7e2ef;
            --text: #1b2430;
            --text-dim: #5e6b7a;
            --muted: #7e8b9b;
        }

        * {
            box-sizing: border-box;
        }

        .dashboard-shell {
            background: var(--bg);
            border: 0;
            padding: 0;
            min-height: 100vh;
            border-radius: 0;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            color: var(--text);
        }

        .dashboard-layout {
            display: grid;
            grid-template-columns: 256px 1fr;
            min-height: 100vh;
            background: var(--bg);
        }

        .sidebar {
            background: var(--surface);
            border-right: 1px solid var(--border);
            padding: 22px 16px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 10px;
        }

        .brand-logo {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--azur);
            color: #fff;
            font-weight: 700;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .brand-text strong {
            display: block;
            color: var(--text);
            font-size: 1.05rem;
            line-height: 1.2;
        }

        .brand-text span {
            color: var(--text-dim);
            font-size: 0.84rem;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 4px 6px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 10px;
            text-decoration: none;
            color: var(--text-dim);
            font-size: 0.95rem;
            font-weight: 600;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
            border: 1px solid transparent;
        }

        .sidebar-link:hover {
            background: #eaf6f4;
            border-color: #cde9e4;
            color: var(--jade-dim);
        }

        .sidebar-link.active {
            background: rgba(0, 196, 179, 0.12);
            border-color: rgba(0, 196, 179, 0.22);
            color: var(--jade-dim);
            font-weight: 700;
        }

        .sidebar-content {
            min-width: 0;
        }

        .dashboard-head {
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            position: relative;
        }

        .dashboard-head::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 2px;
            background: linear-gradient(90deg, var(--azur) 0%, var(--jade) 55%, var(--coq) 100%);
            opacity: 0.45;
        }

        .dashboard-head h1 {
            margin: 0;
            font-size: 1.7rem;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -0.3px;
        }

        .dashboard-head p {
            margin: 4px 0 0;
            color: var(--muted);
            font-size: 0.88rem;
        }

        .logout-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-dim);
            padding: 8px 14px;
            font-size: 0.78rem;
            font-weight: 700;
            border-radius: 7px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.15s;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .logout-btn:hover {
            border-color: var(--coq);
            color: var(--coq);
            background: #fff7f7;
        }

        .dashboard-body {
            padding: 28px 40px;
            max-width: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100%;
            background: #fff;
        }

        .kanban-board-wrapper {
            overflow-x: auto;
            flex: 1;
            margin-left: -40px;
            margin-right: -40px;
            padding-left: 40px;
            padding-right: 40px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        @media (min-width: 768px) {
            .kpi-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .kpi-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 14px 16px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 1px 2px rgba(0, 34, 68, 0.05);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
        }

        .kpi-card:nth-child(1)::before {
            background: var(--jade);
        }

        .kpi-card:nth-child(2)::before {
            background: var(--yellow);
        }

        .kpi-card:nth-child(3)::before {
            background: var(--green);
        }

        .kpi-card:nth-child(4)::before {
            background: var(--muted);
        }

        .kpi-label {
            font-size: 0.68rem;
            font-weight: 800;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
            display: block;
        }

        .kpi-value {
            font-size: 1.85rem;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
        }

        .filters-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 20px;
        }

        .filters-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        @media (min-width: 768px) {
            .filters-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        @media (min-width: 1200px) {
            .filters-grid {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .filter-group-actions {
            justify-content: flex-end;
        }

        .filter-group label {
            font-size: 0.68rem;
            font-weight: 800;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .filter-group select {
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 11px;
            font-size: 0.82rem;
            background: #fff;
            color: var(--text-dim);
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .filter-group select:focus {
            outline: none;
            border-color: var(--jade);
            box-shadow: 0 0 0 3px rgba(0, 196, 179, 0.12);
        }

        .filter-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            min-height: 40px;
        }

        .btn-filter {
            background: var(--jade);
            color: #fff;
            border: 0;
            padding: 9px 16px;
            font-size: 0.8rem;
            font-weight: 700;
            border-radius: 7px;
            cursor: pointer;
            transition: background 0.15s;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .btn-filter:hover {
            background: var(--jade-dim);
        }

        .btn-reset {
            background: transparent;
            color: var(--text-dim);
            border: 1px solid var(--border);
            padding: 9px 16px;
            font-size: 0.8rem;
            font-weight: 700;
            border-radius: 7px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.15s;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .btn-reset:hover {
            border-color: var(--azur);
            color: var(--azur);
            background: #f4f8ff;
        }

        .alerts {
            margin-bottom: 16px;
        }

        .alert-msg {
            padding: 10px 12px;
            border-radius: 7px;
            font-size: 0.78rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .alert-success {
            background: rgba(46, 160, 67, 0.12);
            color: #167a2c;
            border: 1px solid rgba(46, 160, 67, 0.28);
        }

        .alert-error {
            background: rgba(226, 35, 26, 0.1);
            color: #c82820;
            border: 1px solid rgba(226, 35, 26, 0.24);
        }

        .kanban-board {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(6, 340px);
            padding-bottom: 20px;
            min-width: min-content;
            padding-top: 8px;
        }

        @media (max-width: 768px) {
            .dashboard-layout {
                grid-template-columns: 1fr;
            }

            .sidebar {
                border-right: 0;
                border-bottom: 1px solid var(--border);
            }

            .dashboard-body {
                padding: 24px 18px;
            }

            .kanban-board-wrapper {
                margin-left: -18px;
                margin-right: -18px;
                padding-left: 18px;
                padding-right: 18px;
            }

            .kanban-board {
                grid-template-columns: 1fr;
            }
        }

        .kanban-column {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-height: 700px;
        }

        .column-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            padding: 11px 12px;
            font-weight: 700;
            color: #fff;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }

        .column-title {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 0.8rem;
            letter-spacing: 0.2px;
            text-transform: uppercase;
        }

        .column-count {
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 999px;
            padding: 3px 8px;
            font-size: 0.68rem;
            font-weight: 700;
        }

        .column-content {
            flex: 1;
            padding: 10px;
            overflow-y: auto;
            max-height: 900px;
            transition: background-color 0.2s, outline-color 0.2s;
        }

        .column-empty {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #9aa7b5;
            font-size: 0.84rem;
            text-align: center;
            min-height: 140px;
            font-style: italic;
        }

        .ticket {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            box-shadow: 0 1px 2px rgba(0, 34, 68, 0.05);
            transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
            cursor: move;
            display: flex;
            flex-direction: column;
            gap: 8px;
            animation: fadeSlideIn 0.25s ease both;
        }

        .ticket:hover {
            border-color: rgba(0, 196, 179, 0.45);
            box-shadow: 0 0 0 3px rgba(0, 196, 179, 0.08);
            transform: translateY(-1px);
        }

        .ticket-header {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            align-items: center;
            min-width: 0;
        }

        .ticket-id {
            font-size: 0.67rem;
            color: var(--muted);
            font-family: 'DM Mono', monospace;
            font-weight: 500;
            letter-spacing: 0.2px;
            flex: 1;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .ticket-priority {
            display: inline-block;
            font-size: 0.64rem;
            padding: 3px 8px;
            border-radius: 5px;
            font-weight: 700;
            white-space: nowrap;
            border: 1px solid transparent;
            letter-spacing: 0.3px;
            flex-shrink: 0;
        }

        .priority-critical {
            background: rgba(226, 35, 26, 0.12);
            color: #d83a31;
            border-color: rgba(226, 35, 26, 0.25);
        }

        .priority-high {
            background: rgba(240, 180, 41, 0.14);
            color: #be8500;
            border-color: rgba(240, 180, 41, 0.24);
        }

        .priority-medium {
            background: rgba(0, 196, 179, 0.11);
            color: var(--jade-dim);
            border-color: rgba(0, 196, 179, 0.25);
        }

        .priority-low {
            background: rgba(0, 60, 166, 0.1);
            color: var(--azur);
            border-color: rgba(0, 60, 166, 0.2);
        }

        .ticket-title {
            font-size: 0.86rem;
            font-weight: 700;
            color: var(--text);
            margin: 0;
            line-height: 1.3;
        }

        .ticket-category {
            display: inline-block;
            font-size: 0.62rem;
            padding: 3px 8px;
            border-radius: 4px;
            background: #edf3f9;
            border: 1px solid #dce7f2;
            color: var(--muted);
            font-weight: 700;
            font-family: 'DM Mono', monospace;
            width: fit-content;
        }

        .ticket-meta {
            display: flex;
            flex-direction: column;
            gap: 5px;
            font-size: 0.74rem;
            color: var(--text-dim);
            line-height: 1.35;
        }

        .ticket-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .ai-suggestion {
            margin-top: 2px;
            padding: 8px 9px;
            border: 1px solid rgba(0, 60, 166, 0.24);
            background: rgba(0, 60, 166, 0.06);
            border-left: 3px solid var(--azur);
            border-radius: 0 6px 6px 0;
            font-size: 0.72rem;
            color: #244f92;
            line-height: 1.45;
        }

        .ai-suggestion-title {
            display: block;
            margin-bottom: 5px;
            font-size: 0.6rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--azur);
        }

        .ticket-actions {
            display: grid;
            gap: 8px;
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid #e3edf6;
        }

        .ticket-actions select {
            width: 100%;
            border: 1px solid #d0deeb;
            border-radius: 6px;
            padding: 8px 9px;
            font-size: 0.74rem;
            background: #f8fbff;
            color: var(--text-dim);
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .ticket-actions select:focus {
            outline: none;
            border-color: var(--jade);
            box-shadow: 0 0 0 2px rgba(0, 196, 179, 0.12);
        }

        .ticket-actions textarea {
            width: 100%;
            border: 1px solid #d0deeb;
            border-radius: 6px;
            padding: 8px 9px;
            font-size: 0.74rem;
            min-height: 70px;
            color: var(--text-dim);
            resize: vertical;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .btn-save {
            width: 100%;
            background: var(--jade);
            color: #fff;
            border: 0;
            padding: 9px;
            font-size: 0.72rem;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.15s;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .btn-save:hover {
            background: var(--jade-dim);
        }

        .btn-view {
            width: 100%;
            background: transparent;
            color: var(--muted);
            border: 1px solid #d0deeb;
            padding: 9px;
            font-size: 0.72rem;
            font-weight: 700;
            border-radius: 6px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.15s;
            display: block;
            text-align: center;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .btn-view:hover {
            border-color: var(--jade);
            color: var(--jade-dim);
            background: #f0fdfa;
        }

        .review-note {
            font-size: 0.66rem;
            color: var(--muted);
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid #e3edf6;
            font-style: italic;
        }

        .ticket.dragging {
            opacity: 0.45;
            background: #f6fbfb;
        }

        .column-content.drag-over {
            background-color: rgba(0, 196, 179, 0.06);
            border-radius: 8px;
            outline: 2px dashed rgba(0, 196, 179, 0.35);
            outline-offset: -4px;
        }

        .column-content::-webkit-scrollbar {
            width: 4px;
        }

        .column-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .column-content::-webkit-scrollbar-thumb {
            background: #c9d7e5;
            border-radius: 2px;
        }

        .kanban-board-wrapper::-webkit-scrollbar {
            height: 6px;
        }

        .kanban-board-wrapper::-webkit-scrollbar-track {
            background: #eff5fb;
        }

        .kanban-board-wrapper::-webkit-scrollbar-thumb {
            background: #c9d7e5;
            border-radius: 3px;
        }

        @keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <section class="dashboard-shell">
        <div class="dashboard-layout">
            {% include 'moderation/_sidebar.html.twig' with { active: activeTab|default('kanban') } %}

            <div class="sidebar-content">
                <header class="dashboard-head">
                    <div>
                        <h1>{{ pageTitle|default('Tableau de bord Moderation') }}</h1>
                        <p>{{ pageSubtitle|default('Vue Kanban - Gestion centralisee des incidents') }}</p>
                    </div>
                    <a href="{{ path('app_logout') }}" class="logout-btn">Se déconnecter</a>
                </header>

                <div class="dashboard-body">
            <!-- KPIs -->
            <div class="kpi-grid">
                <div class="kpi-card">
                    <span class="kpi-label">Total</span>
                    <div class="kpi-value" id="kpi-total">{{ kpis.total }}</div>
                </div>
                <div class="kpi-card">
                    <span class="kpi-label">En attente</span>
                    <div class="kpi-value" id="kpi-pending">{{ kpis.pending }}</div>
                </div>
                <div class="kpi-card">
                    <span class="kpi-label">Validés</span>
                    <div class="kpi-value" id="kpi-validated">{{ kpis.validated }}</div>
                </div>
                <div class="kpi-card">
                    <span class="kpi-label">Sans suite</span>
                    <div class="kpi-value" id="kpi-dismissed">{{ kpis.dismissed }}</div>
                </div>
            </div>

            <!-- Filtres -->
            <div class="filters-section">
                <form method="get">
                    <div class="filters-grid">
                        <div class="filter-group">
                            <label for="status">Statut</label>
                            <select id="status" name="status">
                                <option value="">Tous</option>
                                {% for status in statuses %}
                                    <option value="{{ status.value }}" {{ filters.status == status.value ? 'selected' : '' }}>
                                        {{ status.label() }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="filter-group">
                            <label for="motif">Motif</label>
                            <select id="motif" name="motif">
                                <option value="">Tous</option>
                                {% for motif in motifs %}
                                    <option value="{{ motif.value }}" {{ filters.motif == motif.value ? 'selected' : '' }}>
                                        {{ motif.label() }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="filter-group">
                            <label for="stop">Arrêt</label>
                            <select id="stop" name="stop">
                                <option value="">Tous</option>
                                {% for stop in stops %}
                                    <option value="{{ stop.id }}" {{ filters.stop == stop.id ? 'selected' : '' }}>
                                        {{ stop.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="filter-group">
                            <label for="user">Utilisateur</label>
                            <select id="user" name="user">
                                <option value="">Tous</option>
                                {% for user in users %}
                                    <option value="{{ user.id }}" {{ filters.user == user.id ? 'selected' : '' }}>
                                        {{ user.email }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="filter-group filter-group-actions">
                            <div class="filter-actions">
                                <button type="submit" class="btn-filter">Filtrer</button>
                                <a href="{{ path(resetRoute|default('app_moderation_tickets')) }}" class="btn-reset">Réinitialiser</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Alerts -->
            {% if app.flashes('success') or app.flashes('error') %}
                <div class="alerts">
                    {% for message in app.flashes('success') %}
                        <div class="alert-msg alert-success">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert-msg alert-error">{{ message }}</div>
                    {% endfor %}
                </div>
            {% endif %}

            <!-- Kanban Board -->
            <div class="kanban-board-wrapper">
                <div class="kanban-board">
                {% set lanes = [
                    {'status': 'en_attente_validation', 'label': 'En attente de validation', 'color': 'bg-yellow-500'},
                    {'status': 'en_cours', 'label': 'En cours', 'color': 'bg-blue-500'},
                    {'status': 'valide', 'label': 'Validé', 'color': 'bg-green-500'},
                    {'status': 'sans_suite', 'label': 'Classé sans suite', 'color': 'bg-gray-500'},
                    {'status': 'escalade_juridique', 'label': 'Transmis au juridique', 'color': 'bg-purple-500'},
                    {'status': 'resolu', 'label': 'Résolu', 'color': 'bg-emerald-500'}
                ] %}

                {% for lane in lanes %}
                    {% set laneTickets = [] %}
                    {% for ticket in tickets %}
                        {% if ticket.status.value == lane.status %}
                            {% set laneTickets = laneTickets|merge([ticket]) %}
                        {% endif %}
                    {% endfor %}

                    <div class="kanban-column">
                        <div class="column-header" style="background-color: {% if lane.color == 'bg-yellow-500' %}#eab308{% elseif lane.color == 'bg-green-500' %}#22c55e{% elseif lane.color == 'bg-blue-500' %}#3b82f6{% elseif lane.color == 'bg-gray-500' %}#6b7280{% elseif lane.color == 'bg-purple-500' %}#a855f7{% elseif lane.color == 'bg-emerald-500' %}#10b981{% endif %}">
                            <div class="column-title">
                                 {{ lane.label }}
                            </div>
                            <div class="column-count">{{ laneTickets|length }}</div>
                        </div>

                        <div class="column-content" data-status="{{ lane.status }}">
                            {% if laneTickets|length == 0 %}
                                <div class="column-empty">Aucun ticket</div>
                            {% else %}
                                {% for ticket in laneTickets %}
                                    <div class="ticket" draggable="true" data-ticket-id="{{ ticket.id }}" data-status="{{ ticket.status.value }}">
                                        <div class="ticket-header">
                                            <span class="ticket-id">{{ ticket.id }}</span>
                                            <span class="ticket-priority priority-{% if ticket.prioriteScore >= 75 %}critical{% elseif ticket.prioriteScore >= 50 %}high{% elseif ticket.prioriteScore >= 25 %}medium{% else %}low{% endif %}">
                                                {% if ticket.prioriteScore >= 75 %}Critique{% elseif ticket.prioriteScore >= 50 %}Haute{% elseif ticket.prioriteScore >= 25 %}Moyenne{% else %}Faible{% endif %}
                                            </span>
                                        </div>

                                        <p class="ticket-title">{{ ticket.motif.label() }}</p>

                                        <span class="ticket-category">{{ ticket.motif.value }}</span>

                                        <div class="ticket-meta">
                                            <span> {{ ticket.stop ? ticket.stop.label : 'Aucun arrêt' }}</span>
                                            <span> {{ ticket.submittedAt|date('d/m/Y H:i') }}</span>
                                            {# <span>️ Confiance: {{ ticket.confianceScore }}%</span> #}
                                        </div>

                                        {% if ticket.suggestion is not empty %}
                                            <div class="ai-suggestion">
                                                <span class="ai-suggestion-title">Suggestion IA</span>
                                                <div>{{ ticket.suggestion|nl2br }}</div>
                                            </div>
                                        {% endif %}

                                        <form class="ticket-actions" method="post" action="{{ path('app_moderation_ticket_status_update', {id: ticket.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('ticket-status-' ~ ticket.id) }}">
                                            <input type="hidden" name="_redirect_route" value="{{ resetRoute|default('app_moderation_tickets') }}">

                                            <select name="status">
                                                {% for status in statuses %}
                                                    <option value="{{ status.value }}" {{ ticket.status.value == status.value ? 'selected' : '' }}>
                                                        {{ status.label() }}
                                                    </option>
                                                {% endfor %}
                                            </select>

                                            <button type="submit" class="btn-save"> Enregistrer</button>
                                            <a href="{{ path('app_ticket_show', {id: ticket.id, token: ticket.accessToken}) }}" class="btn-view">️ Voir</a>
                                        </form>

                                        {% if ticket.reviewedAt %}
                                            <div class="review-note">
                                                Dernière revue: {{ ticket.reviewedAt|date('Y-m-d H:i') }}
                                                {% if ticket.reviewedBy %}
                                                    par {{ ticket.reviewedBy.email }}
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
                </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        let draggedTicket = null;

        // Function to update column counters
        function updateColumnCounters() {
            document.querySelectorAll('.column-content').forEach(column => {
                const ticketCount = column.querySelectorAll('.ticket').length;
                const header = column.closest('.kanban-column').querySelector('.column-header');
                const counter = header.querySelector('.column-count');
                if (counter) {
                    counter.textContent = ticketCount;
                }
            });
        }

        function updateTopKpis() {
            const total = document.querySelectorAll('.ticket').length;
            const pending = document.querySelectorAll('.column-content[data-status="en_attente_validation"] .ticket').length;
            const validated = document.querySelectorAll('.column-content[data-status="valide"] .ticket').length;
            const dismissed = document.querySelectorAll('.column-content[data-status="sans_suite"] .ticket').length;

            const totalEl = document.getElementById('kpi-total');
            const pendingEl = document.getElementById('kpi-pending');
            const validatedEl = document.getElementById('kpi-validated');
            const dismissedEl = document.getElementById('kpi-dismissed');

            if (totalEl) totalEl.textContent = String(total);
            if (pendingEl) pendingEl.textContent = String(pending);
            if (validatedEl) validatedEl.textContent = String(validated);
            if (dismissedEl) dismissedEl.textContent = String(dismissed);
        }

        // Function to attach drag events to a ticket
        function attachDragEvents(ticket) {
            ticket.addEventListener('dragstart', function(e) {
                draggedTicket = this;
                this.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('text/html', this.innerHTML);
            });

            ticket.addEventListener('dragend', function(e) {
                this.classList.remove('dragging');
                document.querySelectorAll('.column-content').forEach(col => {
                    col.classList.remove('drag-over');
                });
            });
        }

        // Initialize drag events for all existing tickets
        document.querySelectorAll('.ticket').forEach(ticket => {
            attachDragEvents(ticket);
        });

        // Setup drop zones
        document.querySelectorAll('.column-content').forEach(column => {
            column.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                this.classList.add('drag-over');
            });

            column.addEventListener('dragleave', function(e) {
                if (e.target === this) {
                    this.classList.remove('drag-over');
                }
            });

            column.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.classList.remove('drag-over');

                if (draggedTicket) {
                    const ticketId = draggedTicket.getAttribute('data-ticket-id');
                    const newStatus = this.getAttribute('data-status');
                    const oldStatus = draggedTicket.getAttribute('data-status');
                    const targetColumn = this;
                    const movedTicket = draggedTicket;
                    const sourceColumn = movedTicket.parentElement;

                    if (newStatus !== oldStatus) {
                        // Optimistic UI update: move immediately, then sync server
                        movedTicket.style.opacity = '0.7';

                        const emptyMsg = targetColumn.querySelector('.column-empty');
                        if (emptyMsg) {
                            emptyMsg.remove();
                        }

                        movedTicket.setAttribute('data-status', newStatus);
                        const movedSelect = movedTicket.querySelector('select[name="status"]');
                        if (movedSelect) {
                            movedSelect.value = newStatus;
                        }
                        targetColumn.appendChild(movedTicket);

                        if (sourceColumn && sourceColumn.querySelectorAll('.ticket').length === 0) {
                            sourceColumn.innerHTML = '<div class="column-empty">Aucun ticket</div>';
                        }

                        updateColumnCounters();
                        updateTopKpis();

                        // Send update to server
                        fetch(`/moderation/tickets/${ticketId}/status-ajax`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({
                                id: ticketId,
                                status: newStatus
                            })
                        })
                        .then(response => {
                            if (!response.ok) throw new Error('Failed to update');
                            movedTicket.style.opacity = '1';
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            // Rollback UI when server update fails
                            movedTicket.setAttribute('data-status', oldStatus);
                            const rollbackSelect = movedTicket.querySelector('select[name="status"]');
                            if (rollbackSelect) {
                                rollbackSelect.value = oldStatus;
                            }
                            if (sourceColumn) {
                                const sourceEmpty = sourceColumn.querySelector('.column-empty');
                                if (sourceEmpty) {
                                    sourceEmpty.remove();
                                }
                                sourceColumn.appendChild(movedTicket);
                            }

                            if (targetColumn.querySelectorAll('.ticket').length === 0) {
                                targetColumn.innerHTML = '<div class="column-empty">Aucun ticket</div>';
                            }

                            movedTicket.style.opacity = '1';
                            updateColumnCounters();
                            updateTopKpis();
                            alert('Erreur lors de la mise à jour du statut');
                        });
                    }

                    draggedTicket = null;
                }
            });
        });

        updateTopKpis();
    </script>
{% endblock %}