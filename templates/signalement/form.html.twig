{% extends 'base.html.twig' %}

{% block title %}Nouveau signalement{% endblock %}

{% block body %}
    <style>

        .ratp-shell {
            --jade: #00c4b3;
            --jade-dim: #00a396;
            --azur: #003ca6;
            --coq: #e2231a;
            --bg: #ffffff;
            --surface: #f8fbff;
            --border: #d7e2ef;
            --text: #1b2430;
            --text-dim: #5e6b7a;
            min-height: 100vh;
            background: radial-gradient(circle at 0% 0%, #eef8f6 0%, #ffffff 56%), radial-gradient(circle at 100% 100%, #edf3ff 0%, transparent 44%);
            border: 0;
            border-radius: 0;
            padding: 28px 16px;
            overflow: visible;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            color: var(--text);
            display: grid;
            place-items: center;
        }

        .ratp-shell .card {
            width: min(780px, 100%);
            margin: 0;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 0;
            box-shadow: 0 12px 32px rgba(0, 34, 68, 0.08);
            overflow: hidden;
        }

        .ratp-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 18px 20px 14px;
            background: #fff;
            color: var(--text);
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .ratp-header::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 2px;
            background: linear-gradient(90deg, var(--azur) 0%, var(--jade) 55%, var(--coq) 100%);
            opacity: 0.45;
        }

        .ratp-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
            letter-spacing: 0.08em;
            font-size: 0.72rem;
            text-transform: uppercase;
            color: var(--text-dim);
        }

        .ratp-badge img {
            width: 30px;
            height: 30px;
            object-fit: contain;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: #fff;
            padding: 4px;
        }

        .ratp-header p {
            margin: 0;
            color: var(--text-dim);
            font-size: 0.86rem;
        }

        .ratp-content {
            background: #fff;
            padding: 24px;
            border-top-left-radius: 0;
            border-top-right-radius: 0;
        }

        .ratp-content h1 {
            margin: 0 0 6px;
            color: var(--text);
        }

        .ratp-content .muted {
            color: var(--text-dim);
            margin-bottom: 18px;
        }

        .ratp-content form > div {
            margin-bottom: 14px;
        }

        .ratp-content label {
            color: var(--text-dim);
            font-weight: 800;
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .ratp-content input,
        .ratp-content select,
        .ratp-content textarea {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 11px 12px;
            color: var(--text);
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .ratp-content input:focus,
        .ratp-content select:focus,
        .ratp-content textarea:focus {
            border-color: var(--jade);
            outline: 3px solid rgba(0, 196, 179, 0.12);
            box-shadow: none;
        }

        .ratp-content ul {
            margin: 6px 0 0;
            padding-left: 18px;
            color: #c82820;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .ratp-submit {
            width: 100%;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 0.84rem;
            background: var(--jade);
            border: 0;
            color: #ffffff;
            font-weight: 700;
            cursor: pointer;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        }

        .ratp-submit:hover {
            background: var(--jade-dim);
        }

        @media (min-width: 768px) {
            .ratp-content {
                padding: 26px 28px;
            }

            .ratp-submit {
                width: auto;
                min-width: 240px;
            }
        }
    </style>

    <section class="card ratp-shell">
        <div class="ratp-header">
            <span class="ratp-badge">
                <img src="https://upload.wikimedia.org/wikipedia/fr/thumb/0/01/RATP.svg/1280px-RATP.svg.png?_=20211228035138" alt="Logo RATP">
                Signalement public
            </span>
            <p>Faire un signalement</p>
        </div>

        <div class="ratp-content">
            <h1>Signaler un incident</h1>
            <p class="muted">Le formulaire est public. Votre lien de suivi vous sera envoye par email.</p>

            {{ form_start(form) }}
                {{ form_row(form.email) }}
                {{ form_row(form.motif) }}
                {{ form_row(form.stop) }}
                {{ form_row(form.incident_date) }}
                {{ form_row(form.details) }}

                <button type="submit" class="ratp-submit">Envoyer le signalement</button>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
