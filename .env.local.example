DATABASE_URL="postgresql://app:change_me@localhost:5432/hackathon_ratp"

N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-endpoint
N8N_WEBHOOK_SECRET=change_me

APP_URL=http://localhost:8000
