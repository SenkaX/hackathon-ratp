# Copier ce fichier en .env.local et adapter les valeurs a votre environnement local.
# Ne pas versionner .env.local.

APP_ENV=dev
APP_DEBUG=true
APP_SECRET=local-dev-secret

# Exemple Supabase (a adapter) :
